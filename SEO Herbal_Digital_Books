      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst aiText = (input.text || input.output || '').toString();\n\nif (!aiText) {\n  return [{ \n    json: { \n      seo_title: 'No article generated',\n      focus_keyword: 'unknown',\n      introduction: 'AI returned empty',\n      dosage: 'N/A',\n      conclusion: 'Check Basic LLM Chain',\n      full_article: 'No article available'\n    } \n  }];\n}\n\n// Extract sections\nfunction extract(text, label) {\n  const pattern = new RegExp(`${label}:\\\\s*([^\\\\n]+(?:\\\\n(?![📌📝📖💊🎯🌿])[^\\\\n]+)*)`, 'i');\n  const match = text.match(pattern);\n  return match ? match[1].trim() : '';\n}\n\nconst title = extract(aiText, 'Title') || 'Herbal Article';\nconst keyword = extract(aiText, 'Keyword') || 'herbs';\nconst intro = extract(aiText, 'Intro') || aiText.substring(0, 300);\nconst dosage = extract(aiText, 'Dosage') || '';\nconst conclusion = extract(aiText, 'Conclusion') || aiText.substring(aiText.length - 300);\n\nreturn [{\n  json: {\n    seo_title: title,\n    focus_keyword: keyword,\n    introduction: intro,\n    dosage: dosage,\n    conclusion: conclusion,\n    full_article: aiText\n  }\n}];"
