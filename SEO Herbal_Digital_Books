      "parameters": {
        "jsCode": "let articleText = \"\";\n\ntry {\n  // Get article from Code in JavaScript2\n  const article = $('Code in JavaScript2').first().json;\n  \n  // Get clean text\n  const title = (article.seo_title || '').substring(0, 80);\n  const intro = (article.introduction || '').substring(0, 250);\n  const dosage = (article.dosage || '').substring(0, 150);\n  const conclusion = (article.conclusion || '').substring(0, 150);\n  \n  articleText = `Title: ${title}\n\nIntro: ${intro}\n\nDosage: ${dosage}\n\nConclusion: ${conclusion}`;\n  \n  // Clean emojis\n  articleText = articleText.replace(/[\\u{1F300}-\\u{1F9FF}\\u{2600}-\\u{27BF}]/gu, '');\n  articleText = articleText.replace(/\\s+/g, ' ').trim();\n  \n} catch(e) {\n  articleText = \"Article about herbs for health\";\n}\n\n// Safety check\nif (!articleText || articleText.length < 20) {\n  articleText = \"Herbal article about natural remedies\";\n}\n\nconst prompt = `Translate the following text into 6 languages.\n\nCRITICAL RULES:\n1. Translate ONLY the actual words\n2. DO NOT add ANY emojis\n3. DO NOT repeat any character\n4. Return ONE clean JSON\n\nReturn ONLY this exact format:\n{\"translations\":{\"Greek\":\"...\",\"Tamil\":\"...\",\"Spanish\":\"...\",\"French\":\"...\",\"German\":\"...\",\"Hindi\":\"...\"}}\n\nTEXT TO TRANSLATE:\n${articleText}`;\n\nreturn [{ json: { prompt: prompt, originalText: articleText } }];"
      },
