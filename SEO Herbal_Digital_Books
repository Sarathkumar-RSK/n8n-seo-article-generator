    {
      "parameters": {
        "jsCode": "let messages = [];\n\ntry {\n  const input = $input.first().json;\n  let llmText = (input.text || input.output || '').toString();\n  \n  if (!llmText) {\n    return [{ json: { message: \"No translation received\" } }];\n  }\n  \n  // Clean response\n  llmText = llmText.replace(/```json/gi, '').replace(/```/g, '').trim();\n  \n  const flags = {\n    \"Greek\": \"🇬🇷\", \"Tamil\": \"🇮🇳\", \"Spanish\": \"🇪🇸\",\n    \"French\": \"🇫🇷\", \"German\": \"🇩🇪\", \"Hindi\": \"🇮🇳\"\n  };\n  \n  const collected = {\n    \"Greek\": \"\", \"Tamil\": \"\", \"Spanish\": \"\",\n    \"French\": \"\", \"German\": \"\", \"Hindi\": \"\"\n  };\n  \n  // Try JSON parse first\n  try {\n    const firstBrace = llmText.indexOf('{');\n    const lastBrace = llmText.lastIndexOf('}');\n    if (firstBrace !== -1) {\n      const data = JSON.parse(llmText.substring(firstBrace, lastBrace + 1));\n      const translations = data.translations || {};\n      for (const lang in translations) {\n        if (collected.hasOwnProperty(lang)) {\n          collected[lang] = String(translations[lang] || '');\n        }\n      }\n    }\n  } catch(e) {\n    // Regex fallback\n    for (const lang of Object.keys(collected)) {\n      const pattern = new RegExp('\"' + lang + '\"\\\\s*:\\\\s*\"((?:[^\"\\\\\\\\]|\\\\\\\\.)*)\"', 's');\n      const match = llmText.match(pattern);\n      if (match && match[1]) {\n        collected[lang] = match[1].replace(/\\\\n/g, '\\n').replace(/\\\\\"/g, '\"');\n      }\n    }\n  }\n  \n  // CLEAN UP - Remove emoji loops!\n  function cleanText(text) {\n    if (!text) return '';\n    \n    // Remove repeated emojis\n    text = text.replace(/([\\u{1F300}-\\u{1F9FF}\\u{2600}-\\u{27BF}\\u{1F1E0}-\\u{1F1FF}])\\1{1,}/gu, '$1');\n    \n    // If too many emojis, remove all\n    const emojiCount = (text.match(/[\\u{1F300}-\\u{1F9FF}\\u{2600}-\\u{27BF}]/gu) || []).length;\n    if (emojiCount > 5) {\n      text = text.replace(/[\\u{1F300}-\\u{1F9FF}\\u{2600}-\\u{27BF}\\u{1F1E0}-\\u{1F1FF}]/gu, '');\n    }\n    \n    // Remove repeated characters\n    text = text.replace(/(.)\\1{4,}/g, '$1$1');\n    \n    // Limit length\n    if (text.length > 1500) {\n      text = text.substring(0, 1500) + '...';\n    }\n    \n    return text.trim();\n  }\n  \n  // Build messages (one per language)\n  for (const lang of Object.keys(collected)) {\n    const flag = flags[lang];\n    const text = cleanText(collected[lang]);\n    \n    if (!text || text.length < 10) {\n      messages.push({ \n        json: { \n          message: flag + \" \" + lang + \": Not available\",\n          language: lang \n        } \n      });\n      continue;\n    }\n    \n    let msg = flag + \" \" + lang + \"\\n\";\n    msg += \"---\\n\\n\";\n    msg += text;\n    \n    if (msg.length > 4000) {\n      msg = msg.substring(0, 3990) + \"...\";\n    }\n    \n    messages.push({ json: { message: msg, language: lang } });\n  }\n  \n} catch (err) {\n  return [{ json: { message: \"Error: \" + err.message } }];\n}\n\nreturn messages.length > 0 ? messages : [{ json: { message: \"No translations\" } }];"
      },
