      "parameters": {
        "jsCode": "// Get the text to translate\nlet textToTranslate = \"\";\n\ntry {\n  textToTranslate = $('Code in JavaScript2').first().json.message;\n} catch (e) {\n  const input = $input.first().json;\n  if (input.result && input.result.text) {\n    textToTranslate = input.result.text;\n  } else {\n    textToTranslate = input.message || input.text || \"\";\n  }\n}\n\nif (!textToTranslate || textToTranslate.length < 2) {\n  textToTranslate = \"No content found to translate\";\n}\n\n// Create ONE item per language (LLM will run 6 times)\nconst languages = [\n  { name: \"Greek\",   flag: \"🇬🇷\" },\n  { name: \"Tamil\",   flag: \"🇮🇳\" },\n  { name: \"Spanish\", flag: \"🇪🇸\" },\n  { name: \"French\",  flag: \"🇫🇷\" },\n  { name: \"German\",  flag: \"🇩🇪\" },\n  { name: \"Hindi\",   flag: \"🇮🇳\" }\n];\n\nreturn languages.map(lang => ({\n  json: {\n    language: lang.name,\n    flag: lang.flag,\n    originalText: textToTranslate,\n    prompt: `You are a professional translator.\n\nTranslate the following text into ${lang.name}.\n\nSTRICT RULES:\n- Return ONLY the translated text, nothing else.\n- Do NOT add explanations, notes, quotes, or markdown.\n- Do NOT say \"Here is the translation\" or similar.\n- Keep all emojis exactly the same (🌿📌📝📖💊🎯).\n- Keep the line breaks and formatting/structure.\n- Translate ONLY the words.\n\nTEXT TO TRANSLATE:\n${textToTranslate}`\n  }\n}));"
      },
