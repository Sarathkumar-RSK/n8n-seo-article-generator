    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst messages = [];\n\nfor (const item of items) {\n  const data = item.json;\n  \n  // Get translated text from LLM output\n  let translated = (data.text || data.output || data.response || '').toString().trim();\n  \n  // Clean up common LLM artifacts\n  translated = translated\n    .replace(/```[\\s\\S]*?\\n/g, '')\n    .replace(/```/g, '')\n    .replace(/^[\"']|[\"']$/g, '')\n    .trim();\n  \n  // Get language info — try from current item first, then fallback\n  let lang = data.language;\n  let flag = data.flag;\n  \n  // If language info was lost, try retrieving from JS2 by index\n  if (!lang) {\n    const idx = items.indexOf(item);\n    const langMap = [\n      { name: \"Greek\",   flag: \"🇬🇷\" },\n      { name: \"Tamil\",   flag: \"🇮🇳\" },\n      { name: \"Spanish\", flag: \"🇪🇸\" },\n      { name: \"French\",  flag: \"🇫🇷\" },\n      { name: \"German\",  flag: \"🇩🇪\" },\n      { name: \"Hindi\",   flag: \"🇮🇳\" }\n    ];\n    lang = langMap[idx]?.name || \"Unknown\";\n    flag = langMap[idx]?.flag || \"🌐\";\n  }\n  \n  if (!translated || translated.length < 2) {\n    messages.push({\n      json: {\n        message: `${flag} ${lang}: ⚠️ Not available`,\n        language: lang\n      }\n    });\n    continue;\n  }\n  \n  let msg = `${flag} ${lang} Translation\\n`;\n  msg += `━━━━━━━━━━━━━━━\\n\\n`;\n  msg += translated;\n  \n  if (msg.length > 4000) {\n    msg = msg.substring(0, 3990) + \"...\";\n  }\n  \n  messages.push({\n    json: {\n      message: msg,\n      language: lang\n    }\n  });\n}\n\nif (messages.length === 0) {\n  return [{ json: { message: \"⚠️ No translations generated\" } }];\n}\n\nreturn messages;"
      },
