        "jsCode": "const data = $input.first().json;\nconst results = data.results || [];\n\nlet articles = [];\nlet reddit = [];\n\nfor (const r of results) {\n  const item = {\n    title: r.title || '',\n    url: r.url || '',\n    snippet: (r.content || '').substring(0, 300)\n  };\n  \n  // Separate Reddit from regular articles\n  if (r.url && r.url.includes('reddit.com')) {\n    reddit.push(item);\n  } else {\n    articles.push(item);\n  }\n}\n\nreturn [{\n  json: {\n    keyword: $('Edit Fields').first().json.keyword,\n    articles: articles,\n    reddit: reddit,\n    totalArticles: articles.length,\n    totalReddit: reddit.length\n  }\n}];"
