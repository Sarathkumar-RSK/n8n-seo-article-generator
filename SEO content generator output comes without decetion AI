        "jsCode": "let text = $input.first().json.text || '';\n\ntext = text.replace(/<think>[\\s\\S]*?<\\/think>/gi, '');\ntext = text.replace(/\\*\\*/g, '').replace(/##/g, '').trim();\ntext = text.replace(/\\s+\\./g, '.');\ntext = text.replace(/\\s{2,}/g, ' ');\ntext = text.trim();\n\nconst keyword = $('Edit Fields1').first().json.keyword || 'topic';\n\nconst titles = [\n  `My Thoughts On ${keyword}`,\n  `${keyword} — A Quick Take`,\n  `Real Talk About ${keyword}`\n];\nconst title = titles[Math.floor(Math.random() * titles.length)];\n\nconst formatted = `📝 ${title}\\n\\n━━━━━━━━━━━━━━━━━━━\\n\\n${text}\\n\\n━━━━━━━━━━━━━━━━━━━\\n#${keyword.replace(/\\s+/g, '')}`;\n\nlet finalText = formatted;\nif (finalText.length > 4000) {\n  finalText = finalText.substring(0, 4000) + '...';\n}\n\nreturn [{ json: { text: finalText } }];"
