    {
      "parameters": {
        "jsCode": "const httpResponse = $input.first().json;\nlet keyword = '';\n\ntry {\n  keyword = $('Edit Fields1').first().json.keyword || 'topic';\n} catch (e) {\n  keyword = 'topic';\n}\n\nlet research = '';\n\ntry {\n  if (httpResponse.query && httpResponse.query.pages) {\n    const pages = httpResponse.query.pages;\n    const pageId = Object.keys(pages)[0];\n    if (pages[pageId] && pages[pageId].extract) {\n      research = pages[pageId].extract;\n    }\n  }\n} catch (e) {\n  research = '';\n}\n\nif (!research || research.length < 100) {\n  research = `${keyword} - write about this topic with detailed information.`;\n}\n\nif (research.length > 2500) {\n  research = research.substring(0, 2500) + '...';\n}\n\nreturn [{ json: { keyword: keyword, research: research } }];"
      },
