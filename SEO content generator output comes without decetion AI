    {
      "parameters": {
        "jsCode": "let text = $input.first().json.text || $input.first().json.output || '';\n\ntext = text.replace(/<think>[\\s\\S]*?<\\/think>/gi, '');\ntext = text.replace(/\\*\\*/g, '').replace(/##/g, '').trim();\n\n// Replace AI phrases with human ones\nconst aiToHuman = {\n  'It is important to note': 'btw,',\n  'In conclusion': 'so yeah,',\n  'Moreover': 'plus,',\n  'Furthermore': 'also,',\n  'Additionally': 'and,',\n  'Therefore': 'so',\n  'However': 'but',\n  'utilize': 'use',\n  'numerous': 'lots of',\n  'demonstrate': 'show',\n  'facilitate': 'help',\n  'beneficial': 'good'\n};\n\nfor (const [ai, human] of Object.entries(aiToHuman)) {\n  const regex = new RegExp('\\\\b' + ai + '\\\\b', 'gi');\n  text = text.replace(regex, human);\n}\n\n// Insert natural fillers\nconst fillers = [\n  ' — honestly — ',\n  ' (you know?) ',\n  ' kinda ',\n  ' I mean, ',\n  ' basically '\n];\n\nconst sentences = text.split('. ');\nif (sentences.length > 5) {\n  const positions = [\n    Math.floor(sentences.length * 0.3),\n    Math.floor(sentences.length * 0.6),\n    Math.floor(sentences.length * 0.8)\n  ];\n  \n  positions.forEach(pos => {\n    if (pos < sentences.length && pos > 0) {\n      const filler = fillers[Math.floor(Math.random() * fillers.length)];\n      sentences[pos] = sentences[pos] + filler;\n    }\n  });\n  \n  text = sentences.join('. ');\n}\n\ntext = text.replace(/\\s+\\./g, '.');\ntext = text.replace(/\\s+,/g, ',');\ntext = text.replace(/\\s{2,}/g, ' ');\ntext = text.trim();\n\nreturn [{ json: { text: text } }];"
      },
