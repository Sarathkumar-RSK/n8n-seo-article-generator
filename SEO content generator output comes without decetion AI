      "parameters": {
        "jsCode": "let text = $input.first().json.text || $input.first().json.output || '';\n\n// Remove think tags\ntext = text.replace(/<think>[\\s\\S]*?<\\/think>/gi, '');\ntext = text.replace(/<\\/?think>/gi, '');\ntext = text.replace(/\\*\\*/g, '').replace(/##/g, '').trim();\n\n// ⚡ 1. Inject 5 TYPOS\nconst typoPairs = [\n  ['the', 'teh'],\n  ['and', 'adn'],\n  ['that', 'taht'],\n  ['with', 'wiht'],\n  ['from', 'form'],\n  ['your', 'yuor'],\n  ['have', 'ahve'],\n  ['this', 'tihs'],\n  ['just', 'jsut'],\n  ['know', 'knwo']\n];\n\nconst used = new Set();\nfor (let i = 0; i < 5; i++) {\n  let attempts = 0;\n  while (attempts < 8) {\n    const t = typoPairs[Math.floor(Math.random() * typoPairs.length)];\n    if (!used.has(t[0])) {\n      const regex = new RegExp('\\\\b' + t[0] + '\\\\b');\n      if (text.match(regex)) {\n        text = text.replace(regex, t[1]);\n        used.add(t[0]);\n        break;\n      }\n    }\n    attempts++;\n  }\n}\n\n// ⚡ 2. Replace AI phrases\nconst aiToHuman = {\n  'It is important to note': 'btw,',\n  'In conclusion': 'so yeah,',\n  'Moreover': 'plus,',\n  'Furthermore': 'also,',\n  'Additionally': 'and,',\n  'Therefore': 'so',\n  'However': 'but',\n  'Nevertheless': 'still,',\n  'utilize': 'use',\n  'numerous': 'lots of',\n  'various': 'different',\n  'demonstrate': 'show',\n  'facilitate': 'help',\n  'beneficial': 'good',\n  'essential': 'needed',\n  'significant': 'big',\n  'enhance': 'boost',\n  'comprehensive': 'full',\n  'consume': 'eat',\n  'research shows': 'people say',\n  'studies indicate': 'I heard'\n};\n\nfor (const [ai, human] of Object.entries(aiToHuman)) {\n  const regex = new RegExp('\\\\b' + ai + '\\\\b', 'gi');\n  text = text.replace(regex, human);\n}\n\n// ⚡ 3. Insert 5 fillers\nconst fillers = [\n  ' — honestly — ',\n  ' (you know?) ',\n  ' kinda ',\n  ' I mean, ',\n  ' like, ',\n  ' (at least I think) ',\n  ' — which is wild — ',\n  ' basically ',\n  ' tbh ',\n  ' — no joke — ',\n  ' ngl, '\n];\n\nconst sentences = text.split('. ');\nif (sentences.length > 5) {\n  const positions = [\n    Math.floor(sentences.length * 0.15),\n    Math.floor(sentences.length * 0.30),\n    Math.floor(sentences.length * 0.50),\n    Math.floor(sentences.length * 0.70),\n    Math.floor(sentences.length * 0.85)\n  ];\n  \n  positions.forEach(pos => {\n    if (pos < sentences.length && pos > 0) {\n      const filler = fillers[Math.floor(Math.random() * fillers.length)];\n      sentences[pos] = sentences[pos] + filler;\n    }\n  });\n  \n  text = sentences.join('. ');\n}\n\n// ⚡ 4. Force casual opener\nif (!text.match(/^(Ok|Look|Honestly|So|Hey|Listen)/i)) {\n  const openers = ['Look, ', 'Honestly, ', 'Ok so, ', 'So basically, '];\n  const opener = openers[Math.floor(Math.random() * openers.length)];\n  text = opener + text.charAt(0).toLowerCase() + text.slice(1);\n}\n\n// ⚡ 5. Insert short punchy sentences between paragraphs\nconst shortInserts = [\n  ' Yeah.',\n  ' True.',\n  ' Wild.',\n  ' Crazy.',\n  ' I know.',\n  ' Felt that.',\n  ' Honestly.',\n  ' For real.',\n  ' No joke.',\n  ' Right?'\n];\n\nconst paragraphs = text.split('\\n\\n');\nif (paragraphs.length > 2) {\n  for (let i = 0; i < paragraphs.length - 1; i++) {\n    if (Math.random() > 0.4) {\n      paragraphs[i] = paragraphs[i] + shortInserts[Math.floor(Math.random() * shortInserts.length)];\n    }\n  }\n  text = paragraphs.join('\\n\\n');\n}\n\n// ⚡ 6. Random punctuation chaos\nconst sents = text.split('. ');\nif (sents.length > 6) {\n  const pos1 = Math.floor(Math.random() * sents.length);\n  sents[pos1] = sents[pos1] + '...';\n  \n  const pos2 = Math.floor(Math.random() * sents.length);\n  if (pos2 !== pos1) sents[pos2] = sents[pos2] + '!';\n  \n  const pos3 = Math.floor(Math.random() * sents.length);\n  if (pos3 !== pos1 && pos3 !== pos2) sents[pos3] = sents[pos3] + '??';\n  \n  text = sents.join('. ');\n}\n\n// ⚡ 7. Add casual ending\nconst endings = ['\\n\\nAnyway.', '\\n\\nYeah, that\\'s it really.', '\\n\\nIdk.', '\\n\\nJust saying.'];\ntext = text + endings[Math.floor(Math.random() * endings.length)];\n\n// Cleanup\ntext = text.replace(/\\s+\\./g, '.');\ntext = text.replace(/\\s+,/g, ',');\ntext = text.replace(/\\.\\.\\.\\./g, '...');\ntext = text.replace(/\\s{2,}/g, ' ');\ntext = text.replace(/\\n{3,}/g, '\\n\\n');\ntext = text.trim();\n\nreturn [{ json: { text: text } }];"
